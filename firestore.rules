rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Questions: public read, authenticated create/update/delete
    match /questions/{questionId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 500;
      allow update, delete: if isAuthenticated();
    }
    
    // Arguments: public read, authenticated write
    match /arguments/{argumentId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    // Categories: public read, authenticated write
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    // Argument categories: public read, authenticated write
    match /argument_categories/{categoryId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    // Links: public read, authenticated write
    match /links/{linkId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    // User profiles (for future use)
    match /users/{userId} {
      allow read: if true;
      allow write: if isAuthenticated() && userId == request.auth.uid;
    }
  }
}
